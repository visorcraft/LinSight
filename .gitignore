# Rust / Cargo
/target
**/target
# Separate target dir used by packaging/arch-v3/PKGBUILD.local so the
# x86_64-v3 build doesn't clobber the baseline ./target.
/target-v3
**/*.rs.bk
Cargo.lock.bak
# Guards against an accidental `cargo vendor` at the workspace
# root. We don't currently vendor here; if that changes, vendor to
# `target/flatpak/vendor` (matches the LinSync convention).
/vendor/
# Allow the committed dev `.cargo/config.toml` (mold+sccache
# wiring) while ignoring scratch / backup files alongside it.
/.cargo/*
!/.cargo/config.toml
# Workspace-root flatpak-builder cache, distinct from the per-
# packaging-dir cache below. flatpak-builder drops `.flatpak-
# builder/` next to the recipe it's pointed at.
/.flatpak-builder/

# Coverage / profiling
*.profraw
*.profdata
lcov.info
tarpaulin-report.html
cobertura.xml
flamegraph.svg
perf.data
perf.data.old

# Packaging — Flatpak (vendored deps regenerated by `just flatpak-vendor`)
/packaging/flatpak/vendor/
/packaging/flatpak/vendor.tar.gz
/packaging/flatpak/build/
/packaging/flatpak/.flatpak-builder/

# Packaging — Arch (`makepkg` outputs, incl. `makepkg -p PKGBUILD.local`)
/packaging/arch/pkg/
/packaging/arch/src/
/packaging/arch-v3/pkg/
/packaging/arch-v3/src/
/packaging/arch*/*.pkg.tar.*
/packaging/arch*/*.log
# Source tarball fetched by the release PKGBUILD's GitHub `source=` line.
# (PKGBUILD.local has no `source=` and never creates this.)
/packaging/arch*/linsight-*.tar.gz

# Packaging — Debian / Fedora / AppImage build outputs
/packaging/debian/debhelper-build-stamp
/packaging/debian/files
/packaging/debian/*.substvars
/packaging/debian/*.debhelper.log
/packaging/debian/.debhelper/
# Fedora: `just fedora-pkg` builds inside a podman container and
# drops the rpmbuild tree + a git-archive source tarball into the
# packaging dir. The .rpm itself is caught by *.rpm below, but the
# tree + tarball aren't — ignore them explicitly so a build-then-
# inspect cycle doesn't dirty the working copy.
/packaging/fedora/_rpmbuild*/
/packaging/fedora/linsight-*.tar.gz
*.deb
*.rpm
*.AppImage
*.AppImage.zsync
# appimage-builder runs from the repo root (see
# packaging/appimage/AppImageBuilder.yml) and drops these beside it.
/AppDir/
/appimage-build/
# Python venv for the appimage tooling (created by the in-container build).
/.venv-appimage/

# Local agent / tooling state
/.superpowers
/docs/superpowers/
/.claude/
/.aider*
# Agent-guidance entry points — kept local, not version-controlled.
# AGENTS.md is the single canonical file; CLAUDE.md and GEMINI.md are
# symlinks to it so each agent CLI auto-loads the same content.
AGENTS.md
CLAUDE.md
GEMINI.md
# Internal implementation plan — kept local, not version-controlled.
PLAN.md

# Local env overrides (never commit secrets)
.env
.env.local
.envrc.local
.cargo/config.local.toml
# mTLS key/cert material for linsight-tunnel: generated locally and passed via
# --cert/--key/--ca paths, never committed. (Tests use in-memory rcgen certs.)
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx
*.der

# Editor / IDE
*.swp
*.swo
*.swn
*~
.idea/
.vscode/
# QML language-server config: holds a machine-specific absolute buildDir.
.qmlls.ini

# OS metadata
.DS_Store
Thumbs.db
Desktop.ini

# AI agent workdirs
.qwen/

# ripgrep override for opencode (un-ignores AGENTS.md etc. for search); local-only
.ignore

# Local release-artifact cache kept by clean_visorcraft_repos
/_releases/
